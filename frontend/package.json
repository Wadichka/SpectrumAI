    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.2",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
