# Корневой .env.example — переменные для docker-compose.
# Скопируй в .env (не коммитится). Для бэкенда отдельный файл — backend/.env.example.

POSTGRES_USER=spectrumai
POSTGRES_PASSWORD=spectrumai
POSTGRES_DB=spectrumai

DATABASE_URL=postgresql+psycopg://spectrumai:spectrumai@postgres:5432/spectrumai
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000
