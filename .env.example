# Окружение SpectrumAI для docker-compose.
# Скопируй в .env (не коммитится) и поправь пароли перед запуском.
# Запуск: docker compose up -d --build

# --- PostgreSQL ---
POSTGRES_USER=spectrumai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=spectrumai

# --- Backend ---
# Origin'ы, разрешённые для CORS. В standalone-режиме это адрес nginx.
CORS_ORIGINS=http://localhost
# Количество gunicorn-воркеров (по 1 модель в RAM на воркер).
GUNICORN_WORKERS=2
# Уровень логирования (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO
# Устройство ML-инференса (cpu | cuda).
ML_DEVICE=cpu

# --- ML checkpoints (фаза 2, предзащитный прототип) ---
# Пути относительны /models внутри docker-compose backend volume (./models:/models:ro).
ML_CNN_CHECKPOINT=/models/checkpoints/cnn1d-predefense-0.5.0/best.pt
ML_CONTRASTIVE_CHECKPOINT=/models/checkpoints/contrastive-predefense-0.5.0/best.pt
ML_FAISS_ROOT=/models/faiss/contrastive-predefense-0.5.0

# Токен Hugging Face для обучения
HF_TOKEN=
